<weaponBlueprint name="CO_RAIL_ADAPTER">
	<type>LASER</type>
	<title>Pulse Rifle 'Adapter'</title>
	<short>'Adapter'</short>
	<tip>co_tip_adapter</tip>
	<desc>UOY T'NDLUOHD EES SHIT</desc> <!-- ~5% crossout desc-->
	<descriptionOverride>A pulse rifle desinged by the Ravagers based on a light burst laser. It has a much higher rate of fire compared to its forefather, which compensates for the reduced damage.

		Stats:
		Required Power: 2
		Charge Time: 3.5 seconds
		Accuracy Bonus: +5%
		
		Shots Per Charge: 3

		Total Crew Damage: 5
		
		Breach Chance: 10%
		
		Total Shield Damage: 1
		Total Super Shield Damage: 1

		Perk: If the first two projectiles in a single burst hit the hull, the last projectile will deal 1 hull damage.
		
		Default Price: 80~   -   Selling Price: 40~
	</descriptionOverride>
	<tooltip>If the first two projectiles in a single burst hit the hull, the last projectile will deal 1 hull damage.</tooltip>
