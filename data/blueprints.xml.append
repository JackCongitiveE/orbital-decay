<weaponBlueprint name="CO_RAIL_ASTREAUS">
	<type>LASER</type>
	<title>Pulse Accelerator 'Astreaus'</title>
	<short>'Astreaus'</short>
	<tip>co_tip_astreaus</tip>
	<desc>UOY T'NDLUOHD EES SHIT</desc> <!-- ~10% crossout desc-->
	<descriptionOverride>Even for the Ravagers, pulse accelerators were once something new. The 'Astreaus' was the first of its kind and far from the most stable, but the Ravagers' regenerative abilities smoothed over the defects of this weapon.

		Stats:
		Required Power: 3
		Charge Time: 8 seconds
		Accuracy Bonus: +20%

		Max Charges: 5
		Bonus Charging Speed: x2 per charge
		
		Base Hull Damage: 1; +0.67 per charge
		Total System Damage: 1; +0.67 per charge
		Total Crew Damage: 15; +10 per charge
		Shield Piercing: 1; +0.67 per charge
		
		Breach Chance: 10%; +10% per charge
		
		Perk: When this weapon reaches its final charge, it will automatically fire at a random enemy system, dealing 1 damage to your weapon control and hull.

		Default Price: 90~   -   Selling Price: 45~
	</descriptionOverride>
	<tooltip>When this weapon reaches maximum charge, it will automatically fire at a random enemy system, dealing 1 damage to your weapon control and hull.</tooltip>
	<damage>1</damage>
	<shots>1</shots>
	<sp>1</sp>
	<fireChance>0</fireChance>
	<breachChance>1</breachChance>
	<accuracyMod>20</accuracyMod>
	<cooldown>8</cooldown>
	<power>3</power>
	<cost>90</cost>
	<speed>180</speed>
	<rarity>0</rarity>
	<chargeLevels>5</chargeLevels>
	<image>co_charon_proj</image>
	<launchSounds>
		<sound>co_charon_shot</sound>
	</launchSounds>
	<hitShipSounds>
		<sound>hitHull2</sound>
		<sound>hitHull3</sound>
	</hitShipSounds>
	<hitShieldSounds>
		<sound>hitShield1</sound>
		<sound>hitShield2</sound>
		<sound>hitShield3</sound>
	</hitShieldSounds>
	<missSounds>
		<sound>miss</sound>
	</missSounds>
	<weaponArt>co_rail_astreaus</weaponArt> <!---->
	<iconImage>laser</iconImage>
</weaponBlueprint>

