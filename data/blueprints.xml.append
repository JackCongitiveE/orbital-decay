<shipBlueprint name="CO_PLAYER_RAVAGER_FRIGATE_ASSAULT" layout="co_player_ravager_frigate_assault_a" img="co_player_ravager_frigate_assault_a">
	<mv-mapImage>map_icon_co_player_ravager_frigate_assault_a</mv-mapImage>
	<class>Ravager Assault Frigate</class>
	<name>Apocriton</name>
	<desc>The Ravagers' invasion has not gone unnoticed by anyone, including the Federation. Even though, the "mind" of this machine can still man systems at 1 lvl and reveal lifeforms even when sensors are down.</desc>
	<systemList>
		<sensors power="1" room="10" start="true" img="co_room_sensors_smol">
			<slot>
				<direction>up</direction>
				<number>1</number>
			</slot>
		</sensors>
