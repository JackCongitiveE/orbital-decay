					<noPwr>0</noPwr>
					<onePwr>0.867</onePwr>
					<twoPwr>0.667</twoPwr>
					<threePwr>0.534</threePwr>
					<fourPwr>0.1</fourPwr>
				</systemPowerScaling>
				<systemRoomTarget>NONE</systemRoomTarget>
				<systemList>
					<clonebay/>
				</systemList>
			</statBoost>
		</statBoosts>
	</mod-append:aug>
	<mod-append:aug name="CO_SIGIL_HEALING_MR">
	</mod-append:aug>
	<mod-append:aug name="CO_SIGIL_HEALING_HR">
	</mod-append:aug>


</mod:findLike>



