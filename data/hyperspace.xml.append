	<mod-append:race name="co_human_legion_oper">
		<animSheet>co_human_legion_oper</animSheet>
		<teleportMove>true</teleportMove>
		<damageMultiplier>2.2</damageMultiplier>
		<damageTakenMultiplier>0.8</damageTakenMultiplier>
		<fireDamageMultiplier>0.2</fireDamageMultiplier>
		<suffocationModifier>0.2</suffocationModifier>
		<repairSpeed>4.0</repairSpeed>
		<fireRepairMultiplier>5</fireRepairMultiplier>
		<animBase>mantis</animBase>
		<defaultSkillLevel>2</defaultSkillLevel>
		<noClone>true</noClone>
		<cloneLoseSkills>false</cloneLoseSkills>
		<powerEffect>
			<cooldown>1</cooldown>
			<cooldownColor r="249" g="180" b="8"/>
			<jumpCooldown>continue</jumpCooldown>
			<buttonText>T1T#N'S R3C0VER7</buttonText>
			<tooltip>Heals itself for 1.5hp/s when below 55hp</tooltip>
			<req>
				<maxHealth>55</maxHealth>
			</req>
			<temporaryEffect>
				<duration>1</duration>
				<cooldownColor r="249" g="180" b="8"/>
				<trueHealAmount>3</trueHealAmount>
			</temporaryEffect>
			<activateWhenReady>true</activateWhenReady>
		</powerEffect>
		<passiveStatBoosts>
			<!--<statBoost name="trueHealAmount">
				<req>
					<maxHealth>55</maxHealth>
				</req>
				<boostType>FLAT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>SELF</crewTarget>
				<priority>0</priority>
			</statBoost> -->
			<statBoost name="trueHealAmount">
				<boostType>FLAT</boostType>
				<amount>2</amount>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ALL</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<priority>0</priority>
			</statBoost> 
			<statBoost name="repairSpeed">
				<boostType>FLAT</boostType>
				<amount>1</amount>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<affectsSelf>true</affectsSelf>
				<maxStacks>2</maxStacks>
				<whiteList>
					<human_technician/>
					<human_legion/>
					<human_legion_pyro/>
					<unique_cyra/>
					<co_unique_human_legion_oper/>
				</whiteList>
				<systemRoomTarget>ALL</systemRoomTarget>
				<systemList>
					<engines/>
					<pilot/>
					<shields/>
					<weapons/>
					<drones/>
				</systemList>
				<priority>0</priority>
			</statBoost>
		</passiveStatBoosts>
		<powerEffect>
			<cooldown>25</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>droneLaunch</powerSound>
			</powerSounds>
			<req type="enemy">
				<enemyInRoom/>
			</req>
			<buttonText>DRONE</buttonText>
			<tooltip>[COOLDOWN:25s]
				Spawns a temporary Commit drone ally which moves slowly, but can only fight if there is an allied crew in the same room, but not sabotage, repair or man systems. Lasts 30 seconds.</tooltip>
			<cooldownColor r="185" g="185" b="185"/>
			<activateWhenReady enemiesOnly="true">true</activateWhenReady>
			<powerCharges>2</powerCharges>
			<initialCharges>2</initialCharges>
			<chargesPerJump>1</chargesPerJump>
			<spawnCrew>
				<number>1</number>
				<race>co_drone_commit</race>
				<lifetime>30</lifetime>
				<statBoosts>
					<statBoost name="noClone">
						<boostType>SET</boostType>
						<value>true</value>
						<shipTarget>ALL</shipTarget>
						<crewTarget>ALL</crewTarget>
						<priority>999999</priority>
					</statBoost>
				</statBoosts>
			</spawnCrew>
		</powerEffect>
		<deathSounds>
			<deathSound>death1</deathSound>
			<deathSound>death2</deathSound>
		</deathSounds>
		<hasCustomDeathAnimation>true</hasCustomDeathAnimation>
	</mod-append:race>


