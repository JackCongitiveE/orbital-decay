				<crewTarget>ALL</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<priority>-999999</priority>
				<boostAnim>co_ravager_shock</boostAnim>
			</statBoost>
		</statBoosts>
		<icon>icon_co_ravager_protocol</icon>
	</mod-append:aug>
	<mod-append:aug name="CO_RAVAGER_ENERSHIELD">
    	<function name="ENERGY_SHIELD" value="0" useForReqs="true" stackable="false"/>
		<superShield>
			<value>36</value>
			<color r="105" g="10" b="10" a="1"/>
			<!--<shieldImage>ship/enemy_shields_chaos_b.png</shieldImage>-->
		</superShield>
    	<statBoosts>
			<statBoost name="canTeleport">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<priority>9999999</priority>
			</statBoost> 
		</statBoosts>
		<locked/>
		<icon>icon_co_ravager_shield</icon>
	</mod-append:aug>
	<mod-append:aug name="CO_RAVAGER_FADING_CLOAK">
		<function name="FAST_CLOAK" value="3" useForReqs="false" warning="false"/>
		<icon>icon_co_ravager_auto</icon>
		<locked/>
	</mod-append:aug>
	
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
<!-- 							LAB UPGRADES				LAB UPGRADES				LAB UPGRADES				LAB UPGRADES							-->
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
	
	<mod-append:aug name="CO_LAB_RAVAGER_FOCUSING">
		<icon>icon_co_ravager_lab_targeting</icon>
    	<statBoosts>
			<statBoost name="powerEffect">
				<boostType>ADD</boostType>
				<powerEffect>
					<cooldown>15</cooldown>
					<jumpCooldown>continue</jumpCooldown>
					<buttonText>FOCUS</buttonText>
					<tooltip>[COOLDOWN:15s]
					Marks the targeted enemy as a priority target.</tooltip>
					<cooldownColor r="203" g="11" b="11"/>
					<req>
						<enemyInRoom/>
						<extraConditions type="or">
							<fighting>true</fighting>
							<shooting>true</shooting>
						</extraConditions>
					</req>
					<statBoosts>
						<statBoost name="statBoost">
							<duration>10</duration>
							<statBoost name="validTarget">
								<boostType>SET</boostType>
								<value>false</value>
								<shipTarget>CURRENT_ROOM</shipTarget>
								<crewTarget>ALLIES</crewTarget>
								<affectsSelf>false</affectsSelf>
							</statBoost>
							<shipTarget>CREW_TARGET</shipTarget>
							<crewTarget>ENEMIES</crewTarget>
							<droneTarget>ALL</droneTarget>
							<affectsSelf>false</affectsSelf>
							<boostAnim>co_ravager_aim</boostAnim>
						</statBoost>
					</statBoosts>
				</powerEffect>
				<shipTarget>ALL</shipTarget>
                <crewTarget>ALLIES</crewTarget>
				<whiteList load="CO_LIST_CREW_RAVAGER_2STAGE"/>
			</statBoost>
		</statBoosts>
		<locked/>
	</mod-append:aug>
	

<!--||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||||-->
