<events>

	<bossShip yOffset="0">CO_RAVAGER_MERCHANT</bossShip>
	
	<bossShip yOffset="80">CO_SLAYERS_LOGISTICS_CRUISER</bossShip>
	
	<bossShip yOffset="100">CO_ANGEL_BATTLESHIP_PURE</bossShip>



	<!-- 				stoopid ass files						-->
	<eventFile>co_special_angel</eventFile>
	<eventFile>co_special_slayers</eventFile>
	<eventFile>co_special_ravagers</eventFile>
	
	<!-- 					sector files						-->
	<eventFile>co_sector_legion</eventFile>

	<!--					sector music						-->
	<metaVariable name="co_juke_legion" op="set" val="0"/>
	<metaVariable name="co_juke_strays" op="set" val="0"/>

	<!--					legion sector						-->
	<variable name="coords_co_legion" op="set" val="0"/>
	

	<req name="CO_REQ_CITADEL_COORDS" type="any">
		<name>coords_co_legion</name>
	</req>
	<!-- -->
	<!--					ravager sector						-->
	<variable name="coords_co_strays" op="set" val="0"/>

	<req name="CO_REQ_STRAYS_COORDS" type="any">
		<name>coords_co_strays</name>
	</req>
	
	
	<metaVariable name="co_prof_ravagers_meet" op="set" val="0"/>
	<metaVariable name="co_prof_ravagers_reputation" op="set" val="0"/>

	
	<!--				RAVAGER CONTAINERS REQS					-->

	<req name="CO_CHECK_ANY_RAVAGER_CONTAINER" type="any">
		<name>CO_RAVAGER_CONTAINER_EPIC</name>
		<name>CO_RAVAGER_CONTAINER_LEGEND</name>
	</req>
	<req name="CO_CHECK_CO_RAVAGER_SYSOPER_AND_ANY_RAVAGER_CONTAINER" type="all">
		<name>CO_RAVAGER_SYSOPER</name>
		<req type="any">
			<name>CO_RAVAGER_CONTAINER_EPIC</name>
			<name>CO_RAVAGER_CONTAINER_LEGEND</name>
		</req>
	</req>

	<!--					SIGIL/CURSE REQS					-->

	<req name="CO_CHECK_NO_SIGIL_HEALING_MR_AND_NO_LAB_INSTALLED" type="any">
		<name>CO_SIGIL_HEALING_MR</name>
		<name>LAB_INSTALLED</name>
	</req>
	<req name="CO_CHECK_NO_SIGIL_HEALING_MR_AND_LAB_INSTALLED" type="all">
		<req lvl="0" max_lvl="0" >
			<name>CO_SIGIL_HEALING_MR</name>
		</req>
		<req lvl="1" >
			<name>LAB_INSTALLED</name>
		</req>
	</req>
	
	<req name="CO_CHECK_NO_SIGIL_HEALING_HR_AND_MEDBAY" type="all">
		<req lvl="0" max_lvl="0" >
			<name>CO_SIGIL_HEALING_HR</name>
		</req>
		<req lvl="1" >
			<name>medbay</name>
		</req>
	</req>
	<req name="CO_CHECK_SIGIL_HEALING_HR_AND_MEDBAY" type="all">
		<name>CO_SIGIL_HEALING_HR</name>
		<name>medbay</name>
	</req>
	<req name="CO_CHECK_NO_SIGIL_HEALING_HR_AND_CLONEBAY" type="all">
		<req lvl="0" max_lvl="0" >
			<name>CO_SIGIL_HEALING_HR</name>
		</req>
		<req lvl="1" >
			<name>clonebay</name>
		</req>
	</req>
	<req name="CO_CHECK_SIGIL_HEALING_HR_AND_CLONEBAY" type="all">
		<name>CO_SIGIL_HEALING_HR</name>
		<name>clonebay</name>
	</req>

</events>


