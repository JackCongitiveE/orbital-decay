	<mod-append:aug name="CO_SIGIL_SENSOR_LR">
		<function name="ADV_SCANNERS" value="0" useForReqs="false"/>
	</mod-append:aug>
	<mod-append:aug name="CO_SIGIL_SENSOR_MR">
		<function name="ADV_SCANNERS" value="0" useForReqs="false"/>
    	<statBoosts>
			<statBoost name="isTelepathic">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
			</statBoost>
			<statBoost name="isTelepathic">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<priority>0</priority>
			</statBoost>
